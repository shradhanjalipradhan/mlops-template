FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
RUN pip install --no-cache-dir \
    scikit-learn \
    xgboost \
    pandas \
    numpy \
    mlflow \
    boto3 \
    structlog \
    pydantic-settings \
    pyarrow

COPY src/ ./src/
COPY configs/ ./configs/
COPY data/ ./data/

CMD ["python", "-m", "src.training.train"]
